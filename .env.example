# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=warmmate
DB_PASSWORD=your_password_here
DB_NAME=warm_mate

# 服务器配置
PORT=7001
NODE_ENV=development

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# API前缀
API_PREFIX=/alibaba-ai/v1

# 阿里云短信配置（使用SDK标准环境变量名）
# 用于发送短信验证码功能
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here
SMS_SIGN_NAME=速通互联验证服务
SMS_TEMPLATE_CODE=100003

# 阿里云百炼千问 AI 配置
# 用于 AI 心理咨询对话功能
DASHSCOPE_API_KEY=sk-your_api_key_here
